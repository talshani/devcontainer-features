{
    "id": "claude-code-base",
    "name": "Claude Code",
    "version": "1.0.0",
    "description": "Installs the Claude Code CLI (Anthropic) with a per-devcontainer persistent config/auth volume.",
    "containerEnv": {
        "CLAUDE_CONFIG_DIR": "/mnt/claude-code-data"
    },
    "mounts": [
        {
            "source": "claude-code-data-${devcontainerId}",
            "target": "/mnt/claude-code-data",
            "type": "volume"
        }
    ]
}
